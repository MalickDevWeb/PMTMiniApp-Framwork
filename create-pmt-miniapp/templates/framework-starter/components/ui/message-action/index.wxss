.message-action {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  width: 100%;
  box-sizing: border-box;
  padding: 22rpx 24rpx;
  border-radius: 20rpx;
  border: 2rpx solid transparent;
}

.message-action--compacte {
  padding: 18rpx 20rpx;
  border-radius: 16rpx;
}

.message-action--info {
  background: #eef5ff;
  border-color: #c7dcff;
}

.message-action--succes {
  background: #edf9f1;
  border-color: #bde6c8;
}

.message-action--alerte {
  background: #fff6e8;
  border-color: #ffd9a0;
}

.message-action--erreur {
  background: #fff0ef;
  border-color: #f5b9b4;
}

.message-action__contenu {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.message-action__titre {
  font-size: 26rpx;
  font-weight: 700;
  color: #14253d;
}

.message-action__texte {
  font-size: 24rpx;
  line-height: 1.6;
  color: #52657d;
}

.message-action__actions {
  display: flex;
  align-items: center;
  gap: 18rpx;
  flex-wrap: wrap;
}

.message-action__action,
.message-action__fermeture {
  font-size: 22rpx;
  font-weight: 700;
  color: #085ebd;
}

.message-action--erreur .message-action__action,
.message-action--erreur .message-action__fermeture {
  color: #b42318;
}
