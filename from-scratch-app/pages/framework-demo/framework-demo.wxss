page {
  height: 100vh;
  display: flex;
  flex-direction: column;
  background: linear-gradient(180deg, #f5f7fb 0%, #eef3fb 100%);
}

.scrollarea {
  flex: 1;
  overflow-y: hidden;
}

.page-layout {
  min-height: 100%;
  display: flex;
  flex-direction: column;
}

.page-content {
  display: flex;
  flex-direction: column;
  gap: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.page-value {
  display: block;
  margin-bottom: 16rpx;
  font-size: 28rpx;
  color: #22324a;
}

.page-form {
  margin-top: 16rpx;
}

.page-actions {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 16rpx;
}

.badge-list {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.badge-item {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e4ecfb;
  color: #25406d;
  font-size: 24rpx;
  font-weight: 600;
}
