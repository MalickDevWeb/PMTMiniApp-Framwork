.etat-vide {
  width: 100%;
  box-sizing: border-box;
  padding: 28rpx 24rpx;
  border-radius: 22rpx;
  border: 2rpx dashed #cbd8e8;
  background: #f8fbff;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 12rpx;
  text-align: center;
}

.etat-vide--compact {
  padding: 20rpx 18rpx;
  border-radius: 18rpx;
}

.etat-vide__emoji {
  font-size: 44rpx;
  line-height: 1;
}

.etat-vide__titre {
  font-size: 28rpx;
  font-weight: 700;
  color: #14253d;
}

.etat-vide__message {
  font-size: 24rpx;
  line-height: 1.6;
  color: #61738a;
}

.etat-vide__action {
  margin-top: 6rpx;
  font-size: 22rpx;
  font-weight: 700;
  color: #085ebd;
}
