.boite-dialogue-overlay {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  justify-content: center;
  align-items: center;
  z-index: 999;
  animation: osnOverlayIn 0.25s ease-out both;
}

@keyframes osnOverlayIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

.boite-dialogue {
  background: #fff;
  border-radius: 32rpx;
  overflow: hidden;
  width: 100%;
  box-shadow: 0 16rpx 48rpx rgba(0, 0, 0, 0.15);
  animation: osnSlideUp 0.35s ease-out both;
}

@keyframes osnSlideUp {
  from {
    opacity: 0;
    transform: translateY(40rpx);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.boite-dialogue--bottom {
  border-bottom-left-radius: 0;
  border-bottom-right-radius: 0;
  align-self: flex-end;
}

.boite-dialogue__handle {
  width: 64rpx;
  height: 8rpx;
  background: #e5e7eb;
  border-radius: 4rpx;
  margin: 16rpx auto 8rpx;
}

.boite-dialogue__header {
  padding: 28rpx 32rpx 20rpx;
  border-bottom: 1rpx solid #f0f0f0;
}

.boite-dialogue__title {
  font-weight: 700;
  font-size: 30rpx;
  color: #14253d;
}

.boite-dialogue__body {
  padding: 32rpx;
  font-size: 26rpx;
  line-height: 1.6;
  color: #52657d;
}

.boite-dialogue__footer {
  padding: 24rpx 32rpx;
  border-top: 1rpx solid #f0f0f0;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.boite-dialogue__button {
  margin: 0;
  padding: 18rpx 24rpx;
  border-radius: 16rpx;
  font-size: 26rpx;
  font-weight: 700;
}

.boite-dialogue__button--primaire {
  border: none;
  background: #085ebd;
  color: #fff;
}

.boite-dialogue__button--secondaire {
  border: 2rpx solid #d7e1ee;
  background: #fff;
  color: #22324a;
}

.boite-dialogue__loading {
  text-align: center;
  font-size: 24rpx;
  color: #6b7b92;
}
